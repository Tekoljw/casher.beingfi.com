                      </td>
                      <td className="px-4 py-3 font-bold text-gray-900">{order.amount} {order.currency}</td>
                      <td className="px-4 py-3 text-gray-700">
                        <div className="flex items-center">
                          <CreditCard className="h-3.5 w-3.5 mr-1.5 text-blue-500 flex-shrink-0" />
                          {order.payment_method}
                        </div>
                      </td>
                      <td className="px-4 py-3 text-gray-700">
                        <div className="flex items-center">
                          <User className="h-3.5 w-3.5 mr-1.5 text-blue-500 flex-shrink-0" />
                          {order.client}
                        </div>
                      </td>
                      <td className="px-4 py-3 text-gray-700">{order.uniqueCode}</td>
                      <td className="px-4 py-3 text-gray-700">{order.agentFee}%</td>
                      <td className="px-4 py-3 text-gray-700">
                        <div className="flex items-center">
                          <Calendar className="h-3.5 w-3.5 mr-1.5 text-blue-500 flex-shrink-0" />
                          {order.date}
                        </div>
                      </td>
                      <td className="px-4 py-3 text-gray-700">{order.businessAgent}</td>
                      <td className="px-4 py-3 text-center">
                        <Button variant="secondary" size="sm" className="bg-black text-white hover:bg-gray-800 text-xs">
                          <Eye className="h-3.5 w-3.5 mr-1" />
                          查看
                        </Button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
              
              {/* 当没有订单时显示空状态 */}
              {filteredOrders.filter(order => order.status === "已完成").length === 0 && (
                <div className="bg-white p-12 text-center rounded-lg border border-gray-200">
                  <Ban className="h-10 w-10 mx-auto text-gray-300 mb-3" />
                  <p className="text-gray-500">暂无已完成订单</p>
                </div>
              )}
            </div>
          </TabsContent>
          
          <TabsContent value="yiquxiao" className="mt-4 px-0">
            {/* 表格式订单列表 */}
            <div className="overflow-x-auto">
              <table className="w-full text-left rounded-lg overflow-hidden">
                <thead>
                  <tr className="bg-[#f5f7fa] text-gray-600 text-sm">
                    <th className="px-4 py-3 font-medium">订单号</th>
                    <th className="px-4 py-3 font-medium">金额</th>
                    <th className="px-4 py-3 font-medium">支付方式</th>
                    <th className="px-4 py-3 font-medium">客户</th>
                    <th className="px-4 py-3 font-medium">唯一标识</th>
                    <th className="px-4 py-3 font-medium">手续费</th>
                    <th className="px-4 py-3 font-medium">交易时间</th>
                    <th className="px-4 py-3 font-medium">团队</th>
                    <th className="px-4 py-3 font-medium text-center">操作</th>
                  </tr>
                </thead>
                <tbody>
                  {filteredOrders
                    .filter(order => order.status === "已取消")
                    .map((order, index) => (
                    <tr key={order.id} className={`border-t border-gray-200 ${index % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
                      <td className="px-4 py-3">
                        <div className="flex items-center">
                          <CircleDollarSign className="h-4 w-4 mr-1.5 text-gray-500 flex-shrink-0" />
                          <span className="font-medium text-gray-900">{order.id}</span>
                        </div>
                      </td>
                      <td className="px-4 py-3 font-bold text-gray-900">{order.amount} {order.currency}</td>
                      <td className="px-4 py-3 text-gray-700">
                        <div className="flex items-center">
                          <CreditCard className="h-3.5 w-3.5 mr-1.5 text-blue-500 flex-shrink-0" />
                          {order.payment_method}
                        </div>
                      </td>
                      <td className="px-4 py-3 text-gray-700">
                        <div className="flex items-center">
                          <User className="h-3.5 w-3.5 mr-1.5 text-blue-500 flex-shrink-0" />
                          {order.client}
                        </div>
                      </td>
                      <td className="px-4 py-3 text-gray-700">{order.uniqueCode}</td>
                      <td className="px-4 py-3 text-gray-700">{order.agentFee}%</td>
                      <td className="px-4 py-3 text-gray-700">
                        <div className="flex items-center">
                          <Calendar className="h-3.5 w-3.5 mr-1.5 text-blue-500 flex-shrink-0" />
                          {order.date}
                        </div>
                      </td>
                      <td className="px-4 py-3 text-gray-700">{order.businessAgent}</td>
                      <td className="px-4 py-3 text-center">
                        <Button variant="secondary" size="sm" className="bg-black text-white hover:bg-gray-800 text-xs">
                          <Eye className="h-3.5 w-3.5 mr-1" />
                          查看
                        </Button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
              
              {/* 当没有订单时显示空状态 */}
              {filteredOrders.filter(order => order.status === "已取消").length === 0 && (
                <div className="bg-white p-12 text-center rounded-lg border border-gray-200">
                  <Ban className="h-10 w-10 mx-auto text-gray-300 mb-3" />
                  <p className="text-gray-500">暂无已取消订单</p>
                </div>
              )}
            </div>
          </TabsContent>
        </Tabs>
      </div>
      
      {/* 订单详情对话框 */}
      <Dialog open={detailsOpen} onOpenChange={setDetailsOpen}>
        <DialogContent className="max-w-lg">
          <DialogHeader>
            <DialogTitle className="flex items-center justify-between">
              <span>详情</span>
              <Button variant="ghost" size="icon" onClick={() => setDetailsOpen(false)} className="h-8 w-8 absolute right-2 top-2">
                <X className="h-4 w-4" />
              </Button>
            </DialogTitle>
          </DialogHeader>
          
          {selectedOrder && (
            <div className="space-y-4">
              {/* 币种 */}
              <div className="bg-gray-50 px-4 py-3 rounded-md">
                <div className="text-gray-700 text-sm mb-1">币种</div>
                <div className="text-gray-900">{selectedOrder.currency}</div>
              </div>
              
              {/* 账户类型 */}
              <div className="bg-gray-50 px-4 py-3 rounded-md">
                <div className="text-gray-700 text-sm mb-1">账户类型</div>
                <div className="text-gray-900">-</div>
              </div>
              
              {/* 业务类型 */}
              <div className="bg-gray-50 px-4 py-3 rounded-md">
                <div className="text-gray-700 text-sm mb-1">业务类型</div>
                <div className="text-gray-900">{selectedOrder.type}</div>
              </div>
              
              {/* 用户姓名 */}
              <div className="bg-gray-50 px-4 py-3 rounded-md">
                <div className="text-gray-700 text-sm mb-1">用户姓名</div>
                <div className="text-gray-900">{selectedOrder.client}</div>
              </div>
              
              {/* 用户收款账号 */}
              <div className="bg-gray-50 px-4 py-3 rounded-md">
                <div className="text-gray-700 text-sm mb-1">用户收款账号</div>
                <div className="text-gray-900">{selectedOrder.uniqueCode}</div>
              </div>
              
              {/* 订单金额 */}
              <div className="bg-gray-50 px-4 py-3 rounded-md">
                <div className="text-gray-700 text-sm mb-1">订单金额</div>
                <div className="text-gray-900 font-bold">{selectedOrder.amount.toLocaleString()}</div>
              </div>
              
              {/* 唯一标识 */}
              <div className="bg-gray-50 px-4 py-3 rounded-md">
                <div className="text-gray-700 text-sm mb-1">唯一标识</div>
                <div className="text-gray-900">-</div>
              </div>
              
              {/* 当前状态 */}
              <div className="bg-gray-50 px-4 py-3 rounded-md">
                <div className="text-gray-700 text-sm mb-1">当前状态</div>
                <div className="text-gray-900">
                  <Badge variant={
                    selectedOrder.status === "待处理" ? "outline" : 
                    selectedOrder.status === "处理中" ? "secondary" :
                    selectedOrder.status === "已完成" ? "default" : "destructive"
                  }>
                    {selectedOrder.status}
                  </Badge>
                </div>
              </div>
            </div>
          )}
        </DialogContent>
      </Dialog>
    </div>
  );
}