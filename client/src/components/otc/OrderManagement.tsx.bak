                      </td>
                      <td className="px-4 py-3 font-bold text-gray-900">{order.amount} {order.currency}</td>
                      <td className="px-4 py-3 text-gray-700">
                        <div className="flex items-center">
                          <CreditCard className="h-3.5 w-3.5 mr-1.5 text-blue-500 flex-shrink-0" />
                          {order.payment_method}
                        </div>
                      </td>
                      <td className="px-4 py-3 text-gray-700">
                        <div className="flex items-center">
                          <User className="h-3.5 w-3.5 mr-1.5 text-blue-500 flex-shrink-0" />
                          {order.client}
                        </div>
                      </td>
                      <td className="px-4 py-3 text-gray-700">{order.uniqueCode}</td>
                      <td className="px-4 py-3 text-gray-700">{order.agentFee}%</td>
                      <td className="px-4 py-3 text-gray-700">
                        <div className="flex items-center">
                          <Calendar className="h-3.5 w-3.5 mr-1.5 text-blue-500 flex-shrink-0" />
                          {order.date}
                        </div>
                      </td>
                      <td className="px-4 py-3 text-gray-700">{order.businessAgent}</td>
                      <td className="px-4 py-3 text-center">
                        <Button variant="secondary" size="sm" className="bg-black text-white hover:bg-gray-800 text-xs">
                          <Eye className="h-3.5 w-3.5 mr-1" />
                          查看
                        </Button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
              
              {/* 当没有订单时显示空状态 */}
              {filteredOrders.filter(order => order.type === "withdraw" && order.status === "待处理").length === 0 && (
                <div className="bg-white p-12 text-center rounded-lg border border-gray-200">
                  <Ban className="h-10 w-10 mx-auto text-gray-300 mb-3" />
                  <p className="text-gray-500">暂无待处理的付款订单</p>
                </div>
              )}
            </div>
          </TabsContent>
          
          <TabsContent value="yiwancheng" className="mt-4 px-0">
            {/* 表格式订单列表 */}
            <div className="overflow-x-auto">
              <table className="w-full text-left rounded-lg overflow-hidden">
                <thead>
                  <tr className="bg-[#f5f7fa] text-gray-600 text-sm">
                    <th className="px-4 py-3 font-medium">订单号</th>
                    <th className="px-4 py-3 font-medium">金额</th>
                    <th className="px-4 py-3 font-medium">支付方式</th>
                    <th className="px-4 py-3 font-medium">客户</th>
                    <th className="px-4 py-3 font-medium">唯一标识</th>
                    <th className="px-4 py-3 font-medium">手续费</th>
                    <th className="px-4 py-3 font-medium">交易时间</th>
                    <th className="px-4 py-3 font-medium">团队</th>
                    <th className="px-4 py-3 font-medium text-center">操作</th>
                  </tr>
                </thead>
                <tbody>
                  {filteredOrders
                    .filter(order => order.status === "已完成")
                    .map((order, index) => (
                    <tr key={order.id} className={`border-t border-gray-200 ${index % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
                      <td className="px-4 py-3">
                        <div className="flex items-center">
                          <CircleDollarSign className="h-4 w-4 mr-1.5 text-blue-500 flex-shrink-0" />
                          <span className="font-medium text-gray-900">{order.id}</span>
